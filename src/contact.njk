<section class="contact-panel">
  <span class="eyebrow">Contact</span>
  <h1>Professional inquiries and introductions.</h1>
  <p class="panel-copy">
    For collaboration, advisory work, or general professional contact, email is the most
    reliable path.
  </p>
  <div class="card">
    <p class="panel-copy"><strong>Email:</strong> <a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
    <p class="panel-copy"><strong>Location:</strong> {{ site.location }}</p>
    <p class="panel-copy"><strong>Domain:</strong> <a href="{{ site.domain }}/">{{ site.siteName }}</a></p>
  </div>
</section>
